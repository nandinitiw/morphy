{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "types": ["vite/client"],
    "allowImportingTsExtensions": true
  },
  "include": ["src/api/**/*.js", "src/test/**/*.js"],
  "exclude": ["node_modules", "dist"]
}
